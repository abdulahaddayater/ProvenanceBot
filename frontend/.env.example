# ProvenanceBot Frontend
#
# Copy to .env.local and fill in values. Never commit real secrets.
# Next.js only exposes vars prefixed with NEXT_PUBLIC_ to the browser.

# Agents API
NEXT_PUBLIC_AGENTS_API_URL=http://localhost:3001

# Stellar / Soroban (read-only client verification)
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
NEXT_PUBLIC_PROVENANCE_CONTRACT_ID=

# WalletConnect / Freighter-style wallet config
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_WALLET_NETWORK=TESTNET
NEXT_PUBLIC_APP_NAME=ProvenanceBot
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Analytics
NEXT_PUBLIC_ANALYTICS_WRITE_KEY=
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Error reporting
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
