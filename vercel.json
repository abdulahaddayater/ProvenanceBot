{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "services": {
    "web": {
      "root": "frontend/",
      "framework": "nextjs",
      "installCommand": "pnpm install",
      "buildCommand": "pnpm --filter @provenancebot/agents build && pnpm --filter @provenancebot/frontend build"
    },
    "agents": {
      "root": "agents/",
      "installCommand": "pnpm install",
      "buildCommand": "pnpm --filter @provenancebot/agents build"
    }
  },
  "rewrites": [
    { "source": "/api/agents/(.*)", "destination": { "service": "agents" } },
    { "source": "/(.*)", "destination": { "service": "web" } }
  ]
}
