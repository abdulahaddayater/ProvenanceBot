{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install",
  "experimentalServices": {
    "web": {
      "root": "frontend",
      "mountPath": "/",
      "framework": "nextjs",
      "buildCommand": "pnpm --filter @provenancebot/agents build && pnpm --filter @provenancebot/frontend build"
    },
    "agents": {
      "root": "agents",
      "mountPath": "/api/agents",
      "buildCommand": "pnpm --filter @provenancebot/agents build"
    }
  }
}
